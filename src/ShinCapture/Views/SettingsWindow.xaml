<Window x:Class="ShinCapture.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="신캡쳐 — 환경설정" Width="500" Height="520"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource BackgroundPrimaryBrush}"
        FontFamily="{DynamicResource AppFont}"
        FontSize="{DynamicResource FontSizeNormal}">
    <Window.Resources>
        <Style x:Key="EditorModeCard" TargetType="{x:Type RadioButton}">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="MinHeight" Value="104"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RadioButton}">
                        <Border x:Name="CardBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CardBorder" Property="Background" Value="#F5F3FF"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CardBorder" Property="Background" Value="#EEF2FF"/>
                                <Setter TargetName="CardBorder" Property="BorderBrush"
                                        Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="CardBorder" Property="BorderThickness" Value="2"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="CardBorder" Property="BorderBrush"
                                        Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="CardBorder" Property="BorderThickness" Value="2"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="CardBorder" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl x:Name="SettingsTabControl" Grid.Row="0" Background="Transparent" BorderThickness="0">
            <!-- 일반 탭 -->
            <TabItem Header="일반">
                <StackPanel Margin="12,16,12,0" VerticalAlignment="Top">
                    <CheckBox x:Name="ChkAutoStart" Content="Windows 시작 시 자동 실행" Margin="0,0,0,12"/>
                    <CheckBox x:Name="ChkMinimizeToTray" Content="닫기 시 트레이로 최소화" Margin="0,0,0,12"/>
                </StackPanel>
            </TabItem>

            <!-- 캡쳐 탭 -->
            <TabItem Header="캡쳐">
                <StackPanel Margin="12,16,12,0" VerticalAlignment="Top">
                    <TextBlock Text="캡쳐 후 동작" Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="{DynamicResource FontSizeSmall}" Margin="0,0,0,4"/>
                    <ComboBox x:Name="CmbAfterCapture" Margin="0,0,0,12">
                        <ComboBoxItem Content="편집기 열기" Tag="OpenEditor"/>
                        <ComboBoxItem Content="바로 저장" Tag="SaveDirectly"/>
                        <ComboBoxItem Content="클립보드만" Tag="ClipboardOnly"/>
                    </ComboBox>

                    <TextBlock Text="편집기 창 크기" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,2"/>
                    <TextBlock Text="새 캡처를 열 때 편집기 창이 어떻게 유지될지 정합니다."
                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                               TextWrapping="Wrap" Margin="0,0,0,8"/>
                    <UniformGrid Columns="3" Rows="1" Margin="0,0,0,12">
                        <RadioButton x:Name="RbEditorRemember" GroupName="EditorWindowSizeMode"
                                     Style="{StaticResource EditorModeCard}" Margin="0,0,4,0"
                                     AutomationProperties.Name="마지막 크기">
                            <StackPanel>
                                <Grid Height="26">
                                    <Path Width="30" Height="24" HorizontalAlignment="Left"
                                          Data="M 2,3 L 26,3 L 26,21 L 2,21 Z M 2,8 L 26,8 M 18,14 L 23,19 M 19,19 L 23,19 L 23,15"
                                          Stretch="Uniform" Stroke="{DynamicResource AccentBrush}"
                                          StrokeThickness="1.5" StrokeLineJoin="Round"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                            Background="#EEF2FF" CornerRadius="5" Padding="5,2">
                                        <TextBlock Text="권장" Foreground="{DynamicResource AccentBrush}"
                                                   FontSize="10" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                                <TextBlock Text="마지막 크기" FontWeight="SemiBold" FontSize="13"
                                           Margin="0,7,0,2"/>
                                <TextBlock Text="내가 조절한 창 크기" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton x:Name="RbEditorMaximized" GroupName="EditorWindowSizeMode"
                                     Style="{StaticResource EditorModeCard}" Margin="2,0"
                                     AutomationProperties.Name="최대화">
                            <StackPanel>
                                <Path Width="30" Height="24" HorizontalAlignment="Left"
                                      Data="M 2,3 L 26,3 L 26,21 L 2,21 Z M 2,8 L 26,8 M 6,11 L 22,11 L 22,18 L 6,18 Z"
                                      Stretch="Uniform" Stroke="{DynamicResource AccentBrush}"
                                      StrokeThickness="1.5" StrokeLineJoin="Round"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                <TextBlock Text="최대화" FontWeight="SemiBold" FontSize="13"
                                           Margin="0,9,0,2"/>
                                <TextBlock Text="작업 표시줄은 유지" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton x:Name="RbEditorFit" GroupName="EditorWindowSizeMode"
                                     Style="{StaticResource EditorModeCard}" Margin="4,0,0,0"
                                     AutomationProperties.Name="이미지 맞춤">
                            <StackPanel>
                                <Path Width="30" Height="24" HorizontalAlignment="Left"
                                      Data="M 2,3 L 26,3 L 26,21 L 2,21 Z M 2,8 L 26,8 M 7,12 L 11,12 L 11,16 M 7,12 L 7,16 M 21,12 L 17,12 L 17,16 M 21,12 L 21,16"
                                      Stretch="Uniform" Stroke="{DynamicResource AccentBrush}"
                                      StrokeThickness="1.5" StrokeLineJoin="Round"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                <TextBlock Text="이미지 맞춤" FontWeight="SemiBold" FontSize="13"
                                           Margin="0,9,0,2"/>
                                <TextBlock Text="캡처마다 자동 조절" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </RadioButton>
                    </UniformGrid>

                    <TextBlock Text="돋보기 배율" Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="{DynamicResource FontSizeSmall}" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="30"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="SldMagnifierZoom" Grid.Column="0"
                                Minimum="1" Maximum="4" TickFrequency="1"
                                IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                   Text="{Binding ElementName=SldMagnifierZoom, Path=Value, StringFormat={}{0:F0}x}"
                                   HorizontalAlignment="Right"/>
                    </Grid>

                    <CheckBox x:Name="ChkShowCrosshair" Content="십자선 표시" Margin="0,0,0,8"/>
                    <CheckBox x:Name="ChkShowColorCode" Content="색상 코드 표시" Margin="0,0,0,8"/>
                </StackPanel>
            </TabItem>

            <!-- 저장 탭 -->
            <TabItem Header="저장">
                <StackPanel Margin="12,16,12,0" VerticalAlignment="Top">
                    <TextBlock Text="기본 형식" Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="{DynamicResource FontSizeSmall}" Margin="0,0,0,4"/>
                    <ComboBox x:Name="CmbDefaultFormat" Margin="0,0,0,12">
                        <ComboBoxItem Content="PNG" Tag="png"/>
                        <ComboBoxItem Content="JPG" Tag="jpg"/>
                        <ComboBoxItem Content="BMP" Tag="bmp"/>
                        <ComboBoxItem Content="GIF" Tag="gif"/>
                    </ComboBox>

                    <TextBlock Text="JPG 품질" Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="{DynamicResource FontSizeSmall}" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="35"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="SldJpgQuality" Grid.Column="0"
                                Minimum="1" Maximum="100" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                   Text="{Binding ElementName=SldJpgQuality, Path=Value, StringFormat={}{0:F0}}"
                                   HorizontalAlignment="Right"/>
                    </Grid>

                    <TextBlock Text="자동 저장 경로" Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="{DynamicResource FontSizeSmall}" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtAutoSavePath" Grid.Column="0" Margin="0,0,4,0" Padding="4,3"/>
                        <Button x:Name="BtnBrowsePath" Grid.Column="1" Content="..." Padding="8,3"
                                Click="OnBrowsePath"/>
                    </Grid>

                    <TextBlock Text="파일명 패턴" Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="{DynamicResource FontSizeSmall}" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtFileNamePattern" Margin="0,0,0,12" Padding="4,3"/>

                    <CheckBox x:Name="ChkAutoSave" Content="자동 저장" Margin="0,0,0,8"/>
                    <CheckBox x:Name="ChkCopyToClipboard" Content="클립보드에 복사"/>
                </StackPanel>
            </TabItem>

            <!-- 단축키 탭 -->
            <TabItem Header="단축키">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12,16,12,0">
                        <TextBlock Text="자주 쓰는" Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="{DynamicResource FontSizeSmall}" Margin="0,0,0,6"/>
                        <StackPanel x:Name="BasicHotkeyPanel"/>

                        <Expander x:Name="AdvancedHotkeyExpander" Header="고급" Margin="0,8,0,0" IsExpanded="False">
                            <StackPanel x:Name="AdvancedHotkeyPanel" Margin="0,6,0,0"/>
                        </Expander>

                        <TextBlock Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="{DynamicResource FontSizeSmall}" Margin="0,8,0,4"
                                   Text="🟢 사용 가능   🟡 신캡쳐 내 다른 기능과 겹침   🔴 다른 앱이 사용 중"/>

                        <Separator Margin="0,4,0,10"/>

                        <CheckBox x:Name="ChkOverridePrintScreen"
                                  Content="PrintScreen 키를 신캡쳐가 독점 사용" Margin="0,0,0,10"
                                  ToolTip="Windows 11의 'PrtSc 키로 화면 캡쳐 열기' 설정을 자동으로 꺼서, PrintScreen 키가 신캡쳐로 전달되도록 합니다. 해제하면 Windows 기본 동작(캡쳐 도구 열기)으로 되돌립니다."/>

                        <Button x:Name="BtnResetHotkeys" Content="기본값으로 복원"
                                HorizontalAlignment="Left" Padding="12,4" Margin="0,0,0,12"
                                Click="OnResetHotkeys"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="OCR 언어" VerticalAlignment="Center" Width="120"/>
                            <ComboBox x:Name="CmbOcrLanguage" Width="200"/>
                            <Button x:Name="BtnOcrLanguageHelp" Content="언어팩 설치" Margin="8,0,0,0"
                                    Padding="8,2" Click="OnOcrLanguageHelp"/>
                        </StackPanel>

                        <CheckBox x:Name="ChkOcrUpscale"
                                  Content="OCR 인식률 향상 전처리"
                                  ToolTip="OCR 실행 전에 작은 이미지 업스케일, 어두운 배경 자동 반전 등을 적용합니다. 원본 캡쳐 이미지에는 영향 없음. 보통 켜두는 것을 권장합니다."/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 지정사이즈 탭 -->
            <TabItem Header="지정사이즈">
                <Grid Margin="12,16,12,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="GridFixedSizes" Grid.Row="0"
                              AutoGenerateColumns="False" CanUserAddRows="False"
                              HeadersVisibility="Column" SelectionMode="Single"
                              BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"
                              Background="{DynamicResource BackgroundSecondaryBrush}"
                              Margin="0,0,0,8">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="이름" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="폭" Binding="{Binding Width}" Width="80"/>
                            <DataGridTextColumn Header="높이" Binding="{Binding Height}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="추가" Padding="16,4" Margin="0,0,8,0" Click="OnAddFixedSize"/>
                        <Button Content="삭제" Padding="16,4" Click="OnDeleteFixedSize"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- AI 탭 -->
            <TabItem Header="AI">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <StackPanel>
                        <CheckBox x:Name="AiEnabledCheckBox" Content="AI 기능 활성화" Margin="0,0,0,16" FontSize="14"/>

                        <TextBlock Text="제공자: OpenAI" FontWeight="Bold" Margin="0,0,0,8"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="API 키:" VerticalAlignment="Center"/>
                            <PasswordBox x:Name="AiKeyBox" Grid.Column="1" Margin="4,0"/>
                            <Button x:Name="AiKeyShowBtn" Grid.Column="2" Content="👁" Width="32" Margin="2,0" Click="OnAiKeyShowClick"/>
                            <Button x:Name="AiKeyValidateBtn" Grid.Column="3" Content="검증" Width="60" Margin="2,0" Click="OnAiKeyValidateClick"/>
                            <Button x:Name="AiKeyDeleteBtn" Grid.Column="4" Content="삭제" Width="60" Margin="2,0" Click="OnAiKeyDeleteClick"/>
                        </Grid>
                        <TextBlock x:Name="AiKeyStatusText" Margin="84,0,0,8" Foreground="#666"/>
                        <TextBlock Margin="84,0,0,16">
                            <Hyperlink NavigateUri="https://platform.openai.com/api-keys" RequestNavigate="OnHyperlinkRequestNavigate">OpenAI 키 발급받기 →</Hyperlink>
                        </TextBlock>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="모델:" VerticalAlignment="Center"/>
                            <ComboBox x:Name="AiModelBox" Grid.Column="1" IsEditable="True" Margin="4,0">
                                <ComboBoxItem>gpt-4o-mini</ComboBoxItem>
                                <ComboBoxItem>gpt-4.1-nano</ComboBoxItem>
                                <ComboBoxItem>gpt-5-mini</ComboBoxItem>
                                <ComboBoxItem>gpt-5-nano</ComboBoxItem>
                            </ComboBox>
                        </Grid>
                        <TextBlock Text="예상 비용: 1회 ≈ $0.0001 ~ $0.001 (모델별 차이)" Margin="84,0,0,16" FontSize="11" Foreground="#888"/>

                        <TextBlock Text="번역" FontWeight="Bold" Margin="0,8,0,8"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="대상 언어:" VerticalAlignment="Center"/>
                            <ComboBox x:Name="AiTargetLangBox" Grid.Column="1" Margin="4,0">
                                <ComboBoxItem Tag="ko">한국어</ComboBoxItem>
                                <ComboBoxItem Tag="en">영어</ComboBoxItem>
                                <ComboBoxItem Tag="ja">일본어</ComboBoxItem>
                                <ComboBoxItem Tag="zh">중국어 (간체)</ComboBoxItem>
                            </ComboBox>
                        </Grid>

                        <Border BorderBrush="#DDD" BorderThickness="1" Padding="12" Background="#FAFAFA">
                            <StackPanel>
                                <TextBlock Text="보안 안내" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#444">
                                    키는 이 PC의 Windows 사용자 계정에만 DPAPI로 암호화 저장됩니다.<LineBreak/>
                                    파일을 다른 PC로 복사해도 사용할 수 없습니다.<LineBreak/>
                                    ⚠ 같은 사용자 권한으로 실행되는 멀웨어가 있다면 어떤 OS 암호화도 우회될 수 있습니다.
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- 하단 버튼 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="취소" Padding="20,6" Margin="0,0,8,0" Click="OnCancel"/>
            <Button Content="저장" Padding="20,6" Click="OnSave"
                    Background="{DynamicResource AccentBrush}" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>
