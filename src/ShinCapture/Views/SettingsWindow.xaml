<Window x:Class="ShinCapture.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="신캡쳐 — 환경설정" Width="500" Height="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource BackgroundPrimaryBrush}"
        FontFamily="{DynamicResource AppFont}"
        FontSize="{DynamicResource FontSizeNormal}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Background="Transparent" BorderThickness="0">
            <!-- 일반 탭 -->
            <TabItem Header="일반">
                <StackPanel Margin="12,16,12,0" VerticalAlignment="Top">
                    <CheckBox x:Name="ChkAutoStart" Content="Windows 시작 시 자동 실행" Margin="0,0,0,12"/>
                    <CheckBox x:Name="ChkMinimizeToTray" Content="닫기 시 트레이로 최소화" Margin="0,0,0,12"/>
                </StackPanel>
            </TabItem>

            <!-- 캡쳐 탭 -->
            <TabItem Header="캡쳐">
                <StackPanel Margin="12,16,12,0" VerticalAlignment="Top">
                    <TextBlock Text="캡쳐 후 동작" Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="{DynamicResource FontSizeSmall}" Margin="0,0,0,4"/>
                    <ComboBox x:Name="CmbAfterCapture" Margin="0,0,0,16">
                        <ComboBoxItem Content="편집기 열기" Tag="OpenEditor"/>
                        <ComboBoxItem Content="바로 저장" Tag="SaveDirectly"/>
                        <ComboBoxItem Content="클립보드만" Tag="ClipboardOnly"/>
                    </ComboBox>

                    <TextBlock Text="돋보기 배율" Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="{DynamicResource FontSizeSmall}" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="30"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="SldMagnifierZoom" Grid.Column="0"
                                Minimum="1" Maximum="4" TickFrequency="1"
                                IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                   Text="{Binding ElementName=SldMagnifierZoom, Path=Value, StringFormat={}{0:F0}x}"
                                   HorizontalAlignment="Right"/>
                    </Grid>

                    <CheckBox x:Name="ChkShowCrosshair" Content="십자선 표시" Margin="0,0,0,12"/>
                    <CheckBox x:Name="ChkShowColorCode" Content="색상 코드 표시" Margin="0,0,0,12"/>
                </StackPanel>
            </TabItem>

            <!-- 저장 탭 -->
            <TabItem Header="저장">
                <StackPanel Margin="12,16,12,0" VerticalAlignment="Top">
                    <TextBlock Text="기본 형식" Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="{DynamicResource FontSizeSmall}" Margin="0,0,0,4"/>
                    <ComboBox x:Name="CmbDefaultFormat" Margin="0,0,0,12">
                        <ComboBoxItem Content="PNG" Tag="png"/>
                        <ComboBoxItem Content="JPG" Tag="jpg"/>
                        <ComboBoxItem Content="BMP" Tag="bmp"/>
                        <ComboBoxItem Content="GIF" Tag="gif"/>
                    </ComboBox>

                    <TextBlock Text="JPG 품질" Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="{DynamicResource FontSizeSmall}" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="35"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="SldJpgQuality" Grid.Column="0"
                                Minimum="1" Maximum="100" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                   Text="{Binding ElementName=SldJpgQuality, Path=Value, StringFormat={}{0:F0}}"
                                   HorizontalAlignment="Right"/>
                    </Grid>

                    <TextBlock Text="자동 저장 경로" Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="{DynamicResource FontSizeSmall}" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtAutoSavePath" Grid.Column="0" Margin="0,0,4,0" Padding="4,3"/>
                        <Button x:Name="BtnBrowsePath" Grid.Column="1" Content="..." Padding="8,3"
                                Click="OnBrowsePath"/>
                    </Grid>

                    <TextBlock Text="파일명 패턴" Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="{DynamicResource FontSizeSmall}" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtFileNamePattern" Margin="0,0,0,12" Padding="4,3"/>

                    <CheckBox x:Name="ChkAutoSave" Content="자동 저장" Margin="0,0,0,8"/>
                    <CheckBox x:Name="ChkCopyToClipboard" Content="클립보드에 복사"/>
                </StackPanel>
            </TabItem>

            <!-- 단축키 탭 -->
            <TabItem Header="단축키">
                <Grid Margin="12,16,12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="영역지정" VerticalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBox x:Name="TxtHkRegion" Grid.Row="0" Grid.Column="1" Padding="4,3" Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="자유형" VerticalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBox x:Name="TxtHkFreeform" Grid.Row="1" Grid.Column="1" Padding="4,3" Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="창 캡쳐" VerticalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBox x:Name="TxtHkWindow" Grid.Row="2" Grid.Column="1" Padding="4,3" Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="단위영역" VerticalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBox x:Name="TxtHkElement" Grid.Row="3" Grid.Column="1" Padding="4,3" Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="전체화면" VerticalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBox x:Name="TxtHkFullscreen" Grid.Row="4" Grid.Column="1" Padding="4,3" Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="스크롤" VerticalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBox x:Name="TxtHkScroll" Grid.Row="5" Grid.Column="1" Padding="4,3" Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="지정사이즈" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtHkFixedSize" Grid.Row="6" Grid.Column="1" Padding="4,3"/>
                </Grid>
            </TabItem>

            <!-- 지정사이즈 탭 -->
            <TabItem Header="지정사이즈">
                <Grid Margin="12,16,12,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="GridFixedSizes" Grid.Row="0"
                              AutoGenerateColumns="False" CanUserAddRows="False"
                              HeadersVisibility="Column" SelectionMode="Single"
                              BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"
                              Background="{DynamicResource BackgroundSecondaryBrush}"
                              Margin="0,0,0,8">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="이름" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="폭" Binding="{Binding Width}" Width="80"/>
                            <DataGridTextColumn Header="높이" Binding="{Binding Height}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="추가" Padding="16,4" Margin="0,0,8,0" Click="OnAddFixedSize"/>
                        <Button Content="삭제" Padding="16,4" Click="OnDeleteFixedSize"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- 하단 버튼 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="취소" Padding="20,6" Margin="0,0,8,0" Click="OnCancel"/>
            <Button Content="저장" Padding="20,6" Click="OnSave"
                    Background="{DynamicResource AccentBrush}" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>
