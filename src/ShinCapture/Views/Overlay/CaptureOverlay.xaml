<Window x:Class="ShinCapture.Views.Overlay.CaptureOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        Cursor="Cross"
        ShowInTaskbar="False">

    <Grid x:Name="RootGrid">

        <!-- Frozen screen background -->
        <Image x:Name="ScreenImage" Stretch="Fill" />

        <!-- Global dim overlay (drawn partially by mode Render; this rect dims everything initially) -->
        <Rectangle x:Name="DimOverlay"
                   Fill="#55000000"
                   IsHitTestVisible="False" />

        <!-- Custom drawing canvas for mode-specific rendering -->
        <Canvas x:Name="DrawCanvas" IsHitTestVisible="False" />

        <!-- Crosshair lines: 흰 라인 + 검정 DropShadow 외곽 → 어떤 배경에서도 가시 -->
        <Line x:Name="CrosshairH"
              Stroke="#FFFFFFFF"
              StrokeThickness="1.5"
              IsHitTestVisible="False"
              Visibility="Collapsed">
            <Line.Effect>
                <DropShadowEffect Color="Black" BlurRadius="3" ShadowDepth="0" Opacity="1"/>
            </Line.Effect>
        </Line>
        <Line x:Name="CrosshairV"
              Stroke="#FFFFFFFF"
              StrokeThickness="1.5"
              IsHitTestVisible="False"
              Visibility="Collapsed">
            <Line.Effect>
                <DropShadowEffect Color="Black" BlurRadius="3" ShadowDepth="0" Opacity="1"/>
            </Line.Effect>
        </Line>

        <!-- Magnifier panel -->
        <Border x:Name="MagnifierBorder"
                Width="200" Height="200"
                BorderBrush="#CCFFFFFF"
                BorderThickness="1"
                CornerRadius="4"
                Background="#EE000000"
                Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Zoom preview -->
                <Image x:Name="MagnifierImage"
                       Grid.Row="0"
                       Stretch="Fill"
                       RenderOptions.BitmapScalingMode="NearestNeighbor" />

                <!-- Magnifier crosshair — 이미지 영역 가득 채우는 십자가 (검정 외곽으로 가시성) -->
                <Grid Grid.Row="0" IsHitTestVisible="False">
                    <!-- 가로선 -->
                    <Border Height="1.5" Background="White"
                            HorizontalAlignment="Stretch" VerticalAlignment="Center">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="2" ShadowDepth="0" Opacity="1"/>
                        </Border.Effect>
                    </Border>
                    <!-- 세로선 -->
                    <Border Width="1.5" Background="White"
                            HorizontalAlignment="Center" VerticalAlignment="Stretch">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="2" ShadowDepth="0" Opacity="1"/>
                        </Border.Effect>
                    </Border>
                </Grid>

                <!-- Info panel -->
                <StackPanel Grid.Row="1"
                            Background="#CC000000"
                            Margin="0,2,0,0">
                    <TextBlock x:Name="MagCoordText"
                               Foreground="White"
                               FontFamily="Consolas"
                               FontSize="11"
                               TextAlignment="Center"
                               Margin="4,2" />
                    <TextBlock x:Name="MagColorText"
                               Foreground="White"
                               FontFamily="Consolas"
                               FontSize="11"
                               TextAlignment="Center"
                               Margin="4,0,4,2" />
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>
