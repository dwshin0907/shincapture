<Window x:Class="ShinCapture.Views.ApiKeyHelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="신캡쳐 — OpenAI API 키 발급 가이드"
        Width="640" Height="640"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="{DynamicResource BackgroundPrimaryBrush}"
        FontFamily="{DynamicResource AppFont}"
        FontSize="{DynamicResource FontSizeNormal}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="🔑 OpenAI API 키 발급 + 신캡쳐 설정 가이드"
                       FontSize="18" FontWeight="SemiBold"/>
            <TextBlock Text="번역 기능을 쓰려면 본인 OpenAI 키가 필요합니다 (BYOK 방식 — 키는 본인 PC에만 저장)"
                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,6,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- 본문 (스텝) -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Step 1 -->
                <Border BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="1"
                        CornerRadius="6" Padding="16" Margin="0,0,0,12"
                        Background="{DynamicResource BackgroundSecondaryBrush}">
                    <StackPanel>
                        <TextBlock Text="① OpenAI 계정 가입 / 로그인" FontWeight="SemiBold" FontSize="14"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,6,0,8" Foreground="{DynamicResource TextSecondaryBrush}">
                            아래 사이트에서 계정을 만들거나 로그인하세요. 신용카드 등록이 필요할 수 있습니다.
                        </TextBlock>
                        <TextBlock>
                            <Hyperlink NavigateUri="https://platform.openai.com/" RequestNavigate="OnHyperlinkRequestNavigate">
                                https://platform.openai.com/ →
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Step 2 -->
                <Border BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="1"
                        CornerRadius="6" Padding="16" Margin="0,0,0,12"
                        Background="{DynamicResource BackgroundSecondaryBrush}">
                    <StackPanel>
                        <TextBlock Text="② API 키 발급" FontWeight="SemiBold" FontSize="14"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,6,0,8" Foreground="{DynamicResource TextSecondaryBrush}">
                            로그인 상태에서 아래 페이지로 이동 → "Create new secret key" 클릭 → 생성된 키를 복사하세요.
                            <LineBreak/>
                            ⚠ 키는 한 번만 표시되니 즉시 복사해두세요.
                        </TextBlock>
                        <TextBlock>
                            <Hyperlink NavigateUri="https://platform.openai.com/api-keys" RequestNavigate="OnHyperlinkRequestNavigate">
                                https://platform.openai.com/api-keys →
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Step 3 -->
                <Border BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="1"
                        CornerRadius="6" Padding="16" Margin="0,0,0,12"
                        Background="{DynamicResource BackgroundSecondaryBrush}">
                    <StackPanel>
                        <TextBlock Text="③ 신캡쳐 설정에 키 입력" FontWeight="SemiBold" FontSize="14"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,6,0,8" Foreground="{DynamicResource TextSecondaryBrush}">
                            신캡쳐 설정 창 → "AI" 탭 → "API 키" 칸에 붙여넣기 → "검증" 클릭 → ✓ 표시되면 OK.
                            <LineBreak/>
                            "AI 기능 활성화" 체크박스도 켜주세요. 키는 Windows DPAPI로 이 PC에만 암호화 저장됩니다.
                        </TextBlock>
                        <Button Content="설정 창 열기" Click="OnOpenSettingsClick"
                                HorizontalAlignment="Left" Padding="14,5"
                                Style="{DynamicResource AccentButton}"/>
                    </StackPanel>
                </Border>

                <!-- 외부 가이드 카드 -->
                <TextBlock Text="📰 더 자세한 가이드 (외부 글)" FontWeight="SemiBold" FontSize="13"
                           Margin="0,12,0,8"/>

                <!-- 카드 1 -->
                <Border x:Name="GuideCard1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        CornerRadius="6" Padding="14,10" Margin="0,0,0,8"
                        Cursor="Hand" Background="White"
                        MouseLeftButtonUp="OnGuideCard1Click">
                    <StackPanel>
                        <TextBlock Text="ChatGPT API키 발급받기" FontWeight="SemiBold" FontSize="13"/>
                        <TextBlock Text="contents.premium.naver.com/market/ai → 클릭하면 브라우저로 열립니다"
                                   FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 카드 2 -->
                <Border x:Name="GuideCard2" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        CornerRadius="6" Padding="14,10" Margin="0,0,0,8"
                        Cursor="Hand" Background="White"
                        MouseLeftButtonUp="OnGuideCard2Click">
                    <StackPanel>
                        <TextBlock Text="ChatGPT API키 무료세팅법" FontWeight="SemiBold" FontSize="13"/>
                        <TextBlock Text="contents.premium.naver.com/market/ai → 클릭하면 브라우저로 열립니다"
                                   FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- 닫기 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="닫기" Click="OnCloseClick" Padding="20,6"/>
        </StackPanel>
    </Grid>
</Window>
