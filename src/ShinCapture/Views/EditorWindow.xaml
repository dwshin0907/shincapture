<Window x:Class="ShinCapture.Views.EditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:editor="clr-namespace:ShinCapture.Editor"
        Title="신캡쳐" Width="1100" Height="750"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundPrimaryBrush}"
        FontFamily="{DynamicResource AppFont}"
        FontSize="{DynamicResource FontSizeNormal}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Main Toolbar -->
        <Border Grid.Row="0" Background="{DynamicResource BackgroundSecondaryBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="{DynamicResource ToolbarPadding}">
            <DockPanel>
                <Border x:Name="BannerArea" DockPanel.Dock="Right" Margin="8,0,0,0"/>
                <WrapPanel x:Name="ToolbarPanel" Orientation="Horizontal"/>
            </DockPanel>
        </Border>

        <!-- Context Property Bar -->
        <Border Grid.Row="1" x:Name="PropertyBorder"
                Background="{DynamicResource BackgroundTertiaryBrush}"
                BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="0,0,0,1"
                Padding="6,4">
            <StackPanel>
                <WrapPanel x:Name="PropertyPanel" Orientation="Horizontal"/>
                <WrapPanel x:Name="SubOptionPanel" Orientation="Horizontal" Margin="0,3,0,0"/>
            </StackPanel>
        </Border>

        <!-- Canvas + History Panel -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Editor Canvas with Scrollbars -->
            <ScrollViewer Grid.Column="0" x:Name="CanvasScroller"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          Focusable="False"
                          PanningMode="Both">
                <editor:EditorCanvas x:Name="Canvas" ClipToBounds="True" Focusable="True"/>
            </ScrollViewer>

            <!-- History Panel -->
            <Border Grid.Column="1" Width="140"
                    Background="{DynamicResource BackgroundSecondaryBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0">
                <DockPanel>
                    <!-- Header (제목 + 버튼) -->
                    <Border DockPanel.Dock="Top" Padding="6,4"
                            BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="0,0,0,1">
                        <DockPanel>
                            <TextBlock Text="캡쳐 기록" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button x:Name="HistorySaveAllBtn" Content="저장" Padding="6,2"
                                        Style="{DynamicResource SmallButton}" Click="OnHistorySaveAll"/>
                                <Button x:Name="HistoryClearBtn" Content="비움" Padding="6,2" Margin="3,0,0,0"
                                        Style="{DynamicResource SmallButton}" Click="OnHistoryClear"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                    <!-- 미니 배너 -->
                    <Border DockPanel.Dock="Top" Padding="6,3" Cursor="Hand"
                            Background="#F0F7FF" BorderBrush="#E0EAFF" BorderThickness="0,0,0,1"
                            x:Name="HistoryBanner" MouseDown="OnHistoryBannerClick"
                            ToolTip="AI 실전 활용법 채널 방문">
                        <TextBlock Text="AI강의 보러가기 >" FontSize="10" Foreground="#0066CC"
                                   HorizontalAlignment="Center"/>
                    </Border>

                    <!-- Thumbnails -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="HistoryPanel" Orientation="Vertical" Margin="4"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <!-- OCR 결과 패널 (기본 숨김) — 좌우 분할 디자인 -->
        <Border Grid.Row="3" x:Name="OcrPanel" Visibility="Collapsed"
                IsVisibleChanged="OnOcrPanelVisibilityChanged"
                Background="{DynamicResource BackgroundSecondaryBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- 헤더 -->
                    <RowDefinition Height="*" MinHeight="140"/>  <!-- 좌우 분할 본문 -->
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Padding="14,10"
                        Background="{DynamicResource BackgroundPrimaryBrush}"
                        BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="0,0,0,1">
                    <DockPanel LastChildFill="True">
                        <Button x:Name="OcrCloseBtn" Content="✕" DockPanel.Dock="Right"
                                Width="24" Height="22" FontSize="12" Margin="6,0,0,0"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{DynamicResource TextSecondaryBrush}"
                                Click="OnOcrClose" Cursor="Hand"
                                ToolTip="OCR 패널 닫기"/>
                        <Button x:Name="OcrTranslateBtn" Content="🌐 번역" DockPanel.Dock="Right"
                                Padding="12,3" Margin="0,0,0,0"
                                Style="{DynamicResource AccentButton}"
                                Click="OnOcrTranslateClick"/>
                        <ComboBox x:Name="OcrTranslateLangBox" DockPanel.Dock="Right"
                                  Width="100" Margin="0,0,4,0"
                                  VerticalAlignment="Center" FontSize="12"
                                  ToolTip="번역 대상 언어">
                            <ComboBoxItem Tag="ko">한국어</ComboBoxItem>
                            <ComboBoxItem Tag="en">영어</ComboBoxItem>
                            <ComboBoxItem Tag="ja">일본어</ComboBoxItem>
                            <ComboBoxItem Tag="zh">중국어 (간체)</ComboBoxItem>
                        </ComboBox>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock x:Name="OcrPanelTitle" Text="🔤 텍스트 추출"
                                       FontWeight="SemiBold" FontSize="13"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="OcrPanelMeta" Text=""
                                       FontSize="11" Margin="10,0,0,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- 좌우 분할 본문 -->
                <Grid Grid.Row="1" x:Name="OcrTranslatedPanel"
                      Background="{DynamicResource BackgroundPrimaryBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 좌측: 원문 -->
                    <DockPanel Grid.Column="0">
                        <Border DockPanel.Dock="Top" Padding="12,5,8,5"
                                Background="#F8FAFC"
                                BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="0,0,0,1">
                            <DockPanel>
                                <Button x:Name="OcrCopyBtn" Content="📋 복사" DockPanel.Dock="Right"
                                        Padding="8,2" FontSize="11" Margin="6,0,0,0"
                                        Background="Transparent" BorderBrush="{DynamicResource BorderLightBrush}"
                                        Foreground="{DynamicResource TextSecondaryBrush}"
                                        Cursor="Hand" Click="OnOcrCopy"
                                        ToolTip="원문 텍스트를 클립보드에 복사"/>
                                <TextBlock x:Name="OcrSourceLangLabel" Text="" DockPanel.Dock="Right"
                                           FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" Margin="6,0,0,0"/>
                                <TextBlock Text="원문" FontWeight="SemiBold" FontSize="12"
                                           VerticalAlignment="Center"/>
                            </DockPanel>
                        </Border>
                        <TextBox x:Name="OcrTextBox"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Background="{DynamicResource BackgroundPrimaryBrush}"
                                 BorderThickness="0" Padding="12,10"
                                 FontFamily="Consolas" FontSize="12"/>
                    </DockPanel>

                    <!-- 가운데 구분선 -->
                    <Border Grid.Column="1" Width="1"
                            Background="{DynamicResource BorderLightBrush}"/>

                    <!-- 우측: 번역 -->
                    <DockPanel Grid.Column="2">
                        <Border DockPanel.Dock="Top" Padding="12,5,8,5"
                                Background="#F8FAFC"
                                BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="0,0,0,1">
                            <DockPanel>
                                <Button x:Name="OcrTranslatedCopyBtn" Content="📋 복사" DockPanel.Dock="Right"
                                        Padding="8,2" FontSize="11" Margin="6,0,0,0"
                                        Background="Transparent" BorderBrush="{DynamicResource BorderLightBrush}"
                                        Foreground="{DynamicResource TextSecondaryBrush}"
                                        Cursor="Hand" Click="OnOcrTranslatedCopyClick"
                                        ToolTip="번역문을 클립보드에 복사"/>
                                <TextBlock x:Name="OcrTargetLangLabel" Text="" DockPanel.Dock="Right"
                                           FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" Margin="6,0,0,0"/>
                                <TextBlock x:Name="OcrTranslatedTitle" Text="번역"
                                           FontWeight="SemiBold" FontSize="12"
                                           VerticalAlignment="Center"/>
                            </DockPanel>
                        </Border>
                        <!-- API 키 미설정 시에만 표시되는 배너 -->
                        <Border x:Name="OcrApiKeyBanner" DockPanel.Dock="Bottom" Visibility="Collapsed"
                                Background="#FEF3C7"
                                BorderBrush="#FCD34D" BorderThickness="0,1,0,0"
                                Padding="12,8" Cursor="Hand"
                                MouseLeftButtonUp="OnApiKeyBannerClick"
                                ToolTip="클릭하면 API 키 발급 가이드가 열립니다">
                            <DockPanel>
                                <TextBlock Text="→" DockPanel.Dock="Right" FontSize="12"
                                           Foreground="#92400E" VerticalAlignment="Center"/>
                                <TextBlock TextWrapping="Wrap" Foreground="#92400E" FontSize="11">
                                    🔑 번역 기능을 쓰려면 OpenAI API 키 등록이 필요합니다 — <Bold>발급법 보기</Bold>
                                </TextBlock>
                            </DockPanel>
                        </Border>
                        <Grid>
                            <TextBox x:Name="OcrTranslatedBox"
                                     IsReadOnly="True" AcceptsReturn="True"
                                     TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                     Background="#FAFBFC"
                                     BorderThickness="0" Padding="12,10"
                                     FontFamily="Consolas" FontSize="12"/>
                            <TextBlock x:Name="OcrTranslatedPlaceholder"
                                       Text="🌐 번역 버튼을 눌러 번역하세요"
                                       Foreground="{DynamicResource TextDisabledBrush}"
                                       FontSize="12" Padding="14,12"
                                       IsHitTestVisible="False"
                                       VerticalAlignment="Top" HorizontalAlignment="Left"/>
                        </Grid>
                    </DockPanel>
                </Grid>

            </Grid>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="4" Background="{DynamicResource BackgroundSecondaryBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="10,5">
            <DockPanel>
                <TextBlock x:Name="StatusText" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="{DynamicResource FontSizeSmall}"/>
                <TextBlock x:Name="ZoomText" VerticalAlignment="Center" Text="100%"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="{DynamicResource FontSizeSmall}" Margin="12,0,0,0"/>
                <!-- 마이크로 홍보 -->
                <TextBlock x:Name="MicroAd" VerticalAlignment="Center" Margin="16,0,0,0"
                           FontSize="10" Cursor="Hand" Foreground="#9CA3AF"
                           MouseDown="OnMicroAdClick"
                           ToolTip="popolong@naver.com">
                    <TextBlock.Text>문의/제휴</TextBlock.Text>
                </TextBlock>
                <Button Content="🔑 API 키 발급법" Margin="16,0,0,0"
                        Style="{DynamicResource AccentButton}"
                        Padding="14,5" FontSize="11"
                        Click="OnApiKeyHelpClick"
                        ToolTip="OpenAI API 키 발급 + 설정 가이드"
                        DockPanel.Dock="Left"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="⚙ 설정" Margin="0,0,4,0"
                            Style="{DynamicResource SubtleButton}" Padding="12,5" Click="OnEditorSettingsClick"/>
                    <Button x:Name="CopyBtn" Content="복사" Margin="0,0,4,0"
                            Style="{DynamicResource SubtleButton}" Padding="12,5" Click="OnCopyClick"/>
                    <Button x:Name="SaveAsBtn" Content="다른이름저장" Margin="0,0,4,0"
                            Style="{DynamicResource SubtleButton}" Padding="12,5" Click="OnSaveAsClick"/>
                    <Button x:Name="SaveBtn" Content="저장"
                            Style="{DynamicResource AccentButton}" Padding="16,5" Click="OnSaveClick"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
