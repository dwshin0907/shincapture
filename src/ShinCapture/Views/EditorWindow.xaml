<Window x:Class="ShinCapture.Views.EditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:editor="clr-namespace:ShinCapture.Editor"
        xmlns:controls="clr-namespace:ShinCapture.Views.Controls"
        Title="신캡쳐" Width="1100" Height="750"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundPrimaryBrush}"
        FontFamily="{DynamicResource AppFont}"
        FontSize="{DynamicResource FontSizeNormal}">
    <Window.Resources>
        <controls:TrayIconGeometryConverter x:Key="EditorIcon"/>
        <Style x:Key="HistoryItemFocusVisual">
            <Setter Property="Control.Template">
                <Setter.Value>
                    <ControlTemplate>
                        <Rectangle Margin="1"
                                   RadiusX="4" RadiusY="4"
                                   Stroke="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"
                                   StrokeThickness="2"
                                   SnapsToDevicePixels="True"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Main command bar -->
        <Border Grid.Row="0" Background="{DynamicResource BackgroundSecondaryBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ScrollViewer Grid.Column="0"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              PanningMode="HorizontalOnly"
                              Focusable="False">
                    <StackPanel x:Name="ToolbarPanel" Orientation="Horizontal"/>
                </ScrollViewer>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,0">
                    <StackPanel x:Name="UtilityCommandPanel" Orientation="Horizontal" Margin="0,0,4,0"/>
                    <Button x:Name="HistoryToggleBtn"
                            Style="{DynamicResource EditorIconButton}"
                            Margin="0,0,4,0"
                            Click="OnHistoryToggleClick"
                            ToolTip="캡처 기록 표시/숨기기"
                            AutomationProperties.Name="캡처 기록 표시 또는 숨기기">
                        <Path Data="{Binding Source=history, Converter={StaticResource EditorIcon}}"
                              Stroke="{DynamicResource TextSecondaryBrush}"
                              StrokeThickness="1.8" StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round" StrokeLineJoin="Round"
                              Width="19" Height="19" Stretch="Uniform"/>
                    </Button>
                    <Button x:Name="CopyBtn" Style="{DynamicResource EditorCommandButton}"
                            Content="복사" Margin="0,0,4,0" Click="OnCopyClick"
                            ToolTip="이미지를 클립보드에 복사 (Ctrl+C)"
                            AutomationProperties.Name="이미지 복사"/>
                    <Button x:Name="SaveAsBtn" Style="{DynamicResource EditorCommandButton}"
                            Content="다른 이름" Margin="0,0,4,0" Click="OnSaveAsClick"
                            ToolTip="다른 이름으로 저장 (Ctrl+Shift+S)"
                            AutomationProperties.Name="다른 이름으로 저장"/>
                    <Button x:Name="SaveBtn" Style="{DynamicResource AccentButton}"
                            Content="저장" MinHeight="36" Padding="16,6" Click="OnSaveClick"
                            ToolTip="빠른 저장 (Ctrl+S)"
                            AutomationProperties.Name="빠른 저장"/>
                    <Button x:Name="MoreBtn" Style="{DynamicResource EditorIconButton}"
                            Margin="4,0,0,0" Click="OnMoreClick"
                            ToolTip="더보기"
                            AutomationProperties.Name="편집기 더보기 메뉴">
                        <Button.ContextMenu>
                            <ContextMenu x:Name="MoreMenu" Placement="Bottom">
                                <MenuItem Header="설정" Click="OnEditorSettingsClick"
                                          AutomationProperties.Name="환경설정 열기"/>
                                <MenuItem Header="API 키 발급 안내" Click="OnApiKeyHelpClick"
                                          AutomationProperties.Name="API 키 발급 안내 열기"/>
                                <Separator/>
                                <MenuItem Header="추천 콘텐츠 · AI 실전 활용법" Click="OnPremiumContentClick"
                                          AutomationProperties.Name="네이버 프리미엄콘텐츠 AI 실전 활용법 열기"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                        <Path Data="{Binding Source=more, Converter={StaticResource EditorIcon}}"
                              Stroke="{DynamicResource TextSecondaryBrush}"
                              StrokeThickness="2" StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round" Width="18" Height="18" Stretch="Uniform"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Context Property Bar -->
        <Border Grid.Row="1" x:Name="PropertyBorder"
                Background="{DynamicResource BackgroundTertiaryBrush}"
                BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="0,0,0,1"
                Padding="8,6" MinHeight="42">
            <StackPanel>
                <WrapPanel x:Name="PropertyPanel" Orientation="Horizontal"/>
                <WrapPanel x:Name="SubOptionPanel" Orientation="Horizontal" Margin="0,3,0,0"/>
            </StackPanel>
        </Border>

        <!-- Canvas + History Panel -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Editor Canvas with Scrollbars -->
            <ScrollViewer Grid.Column="0" x:Name="CanvasScroller"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          Focusable="False"
                          PanningMode="Both">
                <editor:EditorCanvas x:Name="Canvas" ClipToBounds="True" Focusable="True"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </ScrollViewer>

            <!-- History Panel -->
            <Border Grid.Column="1" x:Name="HistoryBorder" Width="180"
                    Background="{DynamicResource BackgroundSecondaryBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0">
                <DockPanel>
                    <!-- Header -->
                    <Border DockPanel.Dock="Top" Padding="10,8"
                            BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="0,0,0,1">
                        <StackPanel>
                            <TextBlock Text="캡처 기록" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <UniformGrid Columns="2">
                                <Button x:Name="HistorySaveAllBtn" Content="전체 저장" Padding="7,3" Margin="0,0,2,0"
                                        Style="{DynamicResource SmallButton}" Click="OnHistorySaveAll"/>
                                <Button x:Name="HistoryClearBtn" Content="비우기" Padding="7,3" Margin="2,0,0,0"
                                        Style="{DynamicResource SmallButton}" Click="OnHistoryClear"/>
                            </UniformGrid>
                        </StackPanel>
                    </Border>
                    <!-- Premium content promotion -->
                    <Border DockPanel.Dock="Bottom" Padding="8"
                            BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="0,1,0,0">
                        <Button Style="{DynamicResource PremiumContentCardButton}"
                                Click="OnPremiumContentClick"
                                ToolTip="네이버 프리미엄콘텐츠 AI 실전 활용법 채널"
                                AutomationProperties.Name="네이버 프리미엄콘텐츠 AI 실전 활용법 열기">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="26" Height="26" CornerRadius="7" Background="#03C75A">
                                    <TextBlock Text="N" Foreground="White" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="7,0,4,0">
                                    <TextBlock Text="AI 실전 활용법" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBlock Text="프리미엄콘텐츠에서 보기" FontSize="9.5"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="→" Foreground="#03A94F"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                    </Border>
                    <!-- Thumbnails -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="HistoryPanel" Orientation="Vertical" Margin="4"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <!-- OCR 결과 패널 (기본 숨김) — 좌우 분할 디자인 -->
        <Border Grid.Row="3" x:Name="OcrPanel" Visibility="Collapsed"
                IsVisibleChanged="OnOcrPanelVisibilityChanged"
                Background="{DynamicResource BackgroundSecondaryBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- 헤더 -->
                    <RowDefinition Height="*" MinHeight="140"/>  <!-- 좌우 분할 본문 -->
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Padding="14,10"
                        Background="{DynamicResource BackgroundPrimaryBrush}"
                        BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="0,0,0,1">
                    <DockPanel LastChildFill="True">
                        <Button x:Name="OcrCloseBtn" DockPanel.Dock="Right"
                                Width="32" Height="32" Margin="6,0,0,0"
                                Style="{DynamicResource EditorIconButton}"
                                Click="OnOcrClose" Cursor="Hand"
                                ToolTip="OCR 패널 닫기"
                                AutomationProperties.Name="OCR 패널 닫기">
                            <Path Data="{Binding Source=close, Converter={StaticResource EditorIcon}}"
                                  Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="1.8"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Width="16" Height="16" Stretch="Uniform"/>
                        </Button>
                        <Button x:Name="OcrTranslateBtn" Content="번역" DockPanel.Dock="Right"
                                Padding="14,6" Margin="0,0,0,0" MinHeight="32"
                                Style="{DynamicResource AccentButton}"
                                Click="OnOcrTranslateClick"
                                AutomationProperties.Name="OCR 결과 번역"/>
                        <ComboBox x:Name="OcrTranslateLangBox" DockPanel.Dock="Right"
                                  Width="100" Margin="0,0,4,0"
                                  VerticalAlignment="Center" FontSize="12"
                                  ToolTip="번역 대상 언어">
                            <ComboBoxItem Tag="ko">한국어</ComboBoxItem>
                            <ComboBoxItem Tag="en">영어</ComboBoxItem>
                            <ComboBoxItem Tag="ja">일본어</ComboBoxItem>
                            <ComboBoxItem Tag="zh">중국어 (간체)</ComboBoxItem>
                        </ComboBox>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock x:Name="OcrPanelTitle" Text="텍스트 추출"
                                       FontWeight="SemiBold" FontSize="13"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="OcrPanelMeta" Text=""
                                       FontSize="11" Margin="10,0,0,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- 좌우 분할 본문 -->
                <Grid Grid.Row="1" x:Name="OcrTranslatedPanel"
                      Background="{DynamicResource BackgroundPrimaryBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 좌측: 원문 -->
                    <DockPanel Grid.Column="0">
                        <Border DockPanel.Dock="Top" Padding="12,5,8,5"
                                Background="#F8FAFC"
                                BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="0,0,0,1">
                            <DockPanel>
                                <Button x:Name="OcrCopyBtn" Content="복사" DockPanel.Dock="Right"
                                        Padding="8,2" FontSize="11" Margin="6,0,0,0"
                                        Background="Transparent" BorderBrush="{DynamicResource BorderLightBrush}"
                                        Foreground="{DynamicResource TextSecondaryBrush}"
                                        Cursor="Hand" Click="OnOcrCopy"
                                        ToolTip="원문 텍스트를 클립보드에 복사"/>
                                <TextBlock x:Name="OcrSourceLangLabel" Text="" DockPanel.Dock="Right"
                                           FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" Margin="6,0,0,0"/>
                                <TextBlock Text="원문" FontWeight="SemiBold" FontSize="12"
                                           VerticalAlignment="Center"/>
                            </DockPanel>
                        </Border>
                        <TextBox x:Name="OcrTextBox"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Background="{DynamicResource BackgroundPrimaryBrush}"
                                 BorderThickness="0" Padding="12,10"
                                 FontFamily="{DynamicResource AppFont}" FontSize="13"/>
                    </DockPanel>

                    <!-- 가운데 구분선 -->
                    <Border Grid.Column="1" Width="1"
                            Background="{DynamicResource BorderLightBrush}"/>

                    <!-- 우측: 번역 -->
                    <DockPanel Grid.Column="2">
                        <Border DockPanel.Dock="Top" Padding="12,5,8,5"
                                Background="#F8FAFC"
                                BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="0,0,0,1">
                            <DockPanel>
                                <Button x:Name="OcrTranslatedCopyBtn" Content="복사" DockPanel.Dock="Right"
                                        Padding="8,2" FontSize="11" Margin="6,0,0,0"
                                        Background="Transparent" BorderBrush="{DynamicResource BorderLightBrush}"
                                        Foreground="{DynamicResource TextSecondaryBrush}"
                                        Cursor="Hand" Click="OnOcrTranslatedCopyClick"
                                        ToolTip="번역문을 클립보드에 복사"/>
                                <TextBlock x:Name="OcrTargetLangLabel" Text="" DockPanel.Dock="Right"
                                           FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" Margin="6,0,0,0"/>
                                <TextBlock x:Name="OcrTranslatedTitle" Text="번역"
                                           FontWeight="SemiBold" FontSize="12"
                                           VerticalAlignment="Center"/>
                            </DockPanel>
                        </Border>
                        <!-- API 키 미설정 시에만 표시되는 배너 -->
                        <Border x:Name="OcrApiKeyBanner" DockPanel.Dock="Bottom" Visibility="Collapsed"
                                Background="#FEF3C7"
                                BorderBrush="#FCD34D" BorderThickness="0,1,0,0"
                                Padding="12,8" Cursor="Hand"
                                MouseLeftButtonUp="OnApiKeyBannerClick"
                                ToolTip="클릭하면 API 키 발급 가이드가 열립니다">
                            <DockPanel>
                                <TextBlock Text="→" DockPanel.Dock="Right" FontSize="12"
                                           Foreground="#92400E" VerticalAlignment="Center"/>
                                <TextBlock TextWrapping="Wrap" Foreground="#92400E" FontSize="11">
                                    번역 기능을 쓰려면 OpenAI API 키 등록이 필요합니다 — <Bold>발급법 보기</Bold>
                                </TextBlock>
                            </DockPanel>
                        </Border>
                        <Grid>
                            <TextBox x:Name="OcrTranslatedBox"
                                     IsReadOnly="True" AcceptsReturn="True"
                                     TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                     Background="#FAFBFC"
                                     BorderThickness="0" Padding="12,10"
                                     FontFamily="{DynamicResource AppFont}" FontSize="13"/>
                            <TextBlock x:Name="OcrTranslatedPlaceholder"
                                       Text="번역 버튼을 눌러 번역하세요"
                                       Foreground="{DynamicResource TextDisabledBrush}"
                                       FontSize="12" Padding="14,12"
                                       IsHitTestVisible="False"
                                       VerticalAlignment="Top" HorizontalAlignment="Left"/>
                        </Grid>
                    </DockPanel>
                </Grid>

            </Grid>
        </Border>

        <!-- Passive status bar + zoom controls -->
        <Border Grid.Row="4" Background="{DynamicResource BackgroundSecondaryBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="{DynamicResource FontSizeSmall}"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{DynamicResource EditorIconButton}" Click="OnZoomOutClick"
                            ToolTip="축소" AutomationProperties.Name="캔버스 축소">
                        <Path Data="{Binding Source=zoom-out, Converter={StaticResource EditorIcon}}"
                              Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="1.8"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Width="17" Height="17" Stretch="Uniform"/>
                    </Button>
                    <Button Style="{DynamicResource SubtleButton}" MinWidth="58" Height="32"
                            Margin="4,0" Padding="8,4" Click="OnZoomResetClick"
                            ToolTip="실제 크기 100%" AutomationProperties.Name="캔버스 실제 크기">
                        <TextBlock x:Name="ZoomText" Text="100%" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </Button>
                    <Button Style="{DynamicResource EditorIconButton}" Click="OnZoomInClick"
                            ToolTip="확대" AutomationProperties.Name="캔버스 확대">
                        <Path Data="{Binding Source=zoom-in, Converter={StaticResource EditorIcon}}"
                              Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="1.8"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Width="17" Height="17" Stretch="Uniform"/>
                    </Button>
                    <Button Style="{DynamicResource EditorIconButton}" Margin="4,0,0,0"
                            Click="OnZoomFitClick" ToolTip="화면에 맞춤"
                            AutomationProperties.Name="캔버스를 화면에 맞춤">
                        <Path Data="{Binding Source=fit, Converter={StaticResource EditorIcon}}"
                              Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="1.8"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Width="17" Height="17" Stretch="Uniform"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
